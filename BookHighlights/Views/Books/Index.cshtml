@model List<BookHighlights.Application.DTOs.BookDto>

@{
    ViewData["Title"] = "Meus Livros";
}

<div class="mb-6">
    <h1 class="text-3xl font-bold mb-2">📚 Meus Livros</h1>
    <p class="text-base-content/70">Gerencie seus livros e destaques</p>
</div>

@if (!Model.Any())
{
    <div class="card bg-base-100 shadow-xl">
        <div class="card-body items-center text-center py-16">
            <div class="text-6xl mb-4">📖</div>
            <h2 class="card-title text-2xl mb-2">Nenhum livro cadastrado</h2>
            <p class="mb-4">Comece adicionando seu primeiro livro para salvar trechos favoritos!</p>
            <a asp-controller="Books" asp-action="Create" class="btn btn-primary btn-lg">
                Cadastrar Primeiro Livro
            </a>
        </div>
    </div>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        @foreach (var book in Model)
        {
            <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow cursor-pointer" 
                 onclick="window.location.href='@Url.Action("Details", "Books", new { id = book.Id })'">
                <div class="card-body">
                    <div class="flex items-start justify-between">
                        <h2 class="card-title text-lg">@book.Title</h2>
                        <span class="badge badge-primary">@book.HighlightsCount</span>
                    </div>
                    @if (!string.IsNullOrEmpty(book.Author))
                    {
                        <p class="text-sm text-base-content/70">✍️ @book.Author</p>
                    }
                    <div class="card-actions justify-end mt-4">
                        <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id" class="btn btn-primary btn-sm">
                            Ver Destaques
                        </a>
                        <form asp-controller="Books" asp-action="Delete" asp-route-id="@book.Id" method="post" class="inline" onsubmit="return confirm('Tem certeza que deseja excluir este livro?');">
                            <button type="submit" class="btn btn-error btn-sm">Excluir</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Three.js Background -->
<div id="three-container" class="fixed inset-0 -z-10 opacity-30"></div>

@section Scripts {
    <script>
        // Three.js background animation
        const container = document.getElementById('three-container');
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
        
        renderer.setSize(window.innerWidth, window.innerHeight);
        container.appendChild(renderer.domElement);

        // Create floating books
        const books = [];
        const bookGeometry = new THREE.BoxGeometry(0.5, 0.7, 0.1);
        
        for (let i = 0; i < 5; i++) {
            const material = new THREE.MeshPhongMaterial({ 
                color: new THREE.Color().setHSL(Math.random(), 0.7, 0.5),
                transparent: true,
                opacity: 0.8
            });
            const book = new THREE.Mesh(bookGeometry, material);
            
            book.position.set(
                (Math.random() - 0.5) * 10,
                (Math.random() - 0.5) * 10,
                (Math.random() - 0.5) * 5 - 5
            );
            
            book.rotation.set(
                Math.random() * Math.PI,
                Math.random() * Math.PI,
                Math.random() * Math.PI
            );
            
            book.velocity = new THREE.Vector3(
                (Math.random() - 0.5) * 0.01,
                (Math.random() - 0.5) * 0.01,
                (Math.random() - 0.5) * 0.01
            );
            
            books.push(book);
            scene.add(book);
        }

        // Lighting
        const ambientLight = new THREE.AmbientLight(0xffffff, 0.5);
        scene.add(ambientLight);
        
        const pointLight = new THREE.PointLight(0xffffff, 1);
        pointLight.position.set(5, 5, 5);
        scene.add(pointLight);

        camera.position.z = 5;

        // Animation loop
        function animate() {
            requestAnimationFrame(animate);
            
            books.forEach(book => {
                book.rotation.x += 0.005;
                book.rotation.y += 0.005;
                
                book.position.add(book.velocity);
                
                if (book.position.x > 6 || book.position.x < -6) book.velocity.x *= -1;
                if (book.position.y > 4 || book.position.y < -4) book.velocity.y *= -1;
                if (book.position.z > 0 || book.position.z < -10) book.velocity.z *= -1;
            });
            
            renderer.render(scene, camera);
        }
        
        animate();

        // Handle resize
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });
    </script>
}
