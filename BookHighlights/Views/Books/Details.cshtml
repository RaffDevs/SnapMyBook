@model BookHighlights.Application.DTOs.BookDto

@{
    ViewData["Title"] = Model.Title;
    var highlights = ViewBag.Highlights as List<BookHighlights.Application.DTOs.HighlightDto> ?? new List<BookHighlights.Application.DTOs.HighlightDto>();
}

<div class="mb-6" x-data="{ showCaptureForm: false }">
    <div class="flex items-center gap-4 mb-4">
        <a asp-controller="Books" asp-action="Index" class="btn btn-ghost btn-sm">
            ← Voltar
        </a>
        <h1 class="text-3xl font-bold">@Model.Title</h1>
    </div>
    
    @if (!string.IsNullOrEmpty(Model.Author))
    {
        <p class="text-lg text-base-content/70 mb-6">✍️ @Model.Author</p>
    }

    <!-- Action Buttons -->
    <div class="flex gap-2 mb-6">
        <button @@click="showCaptureForm = true" class="btn btn-primary flex-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Capturar Trecho
        </button>
    </div>

    <!-- Capture Form Modal -->
    <dialog id="capture_modal" class="modal" @@show="showCaptureForm">
        <div class="modal-box max-w-2xl">
            <form method="dialog">
                <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" @@click="showCaptureForm = false">✕</button>
            </form>
            
            <h3 class="font-bold text-lg mb-4">📸 Capturar Trecho do Livro</h3>
            
            <form asp-controller="Highlights" asp-action="Create" method="post" enctype="multipart/form-data" class="space-y-4">
                <input type="hidden" name="BookId" value="@Model.Id" />
                
                <!-- Camera Capture -->
                <div class="form-control">
                    <label class="label">
                        <span class="label-text font-semibold">Foto do Trecho</span>
                    </label>
                    <div class="border border-base-300 rounded-lg p-4">
                        <video id="video" class="w-full rounded-lg mb-4" autoplay playsinline style="display: none;"></video>
                        <canvas id="canvas" class="w-full rounded-lg mb-4" style="display: none;"></canvas>
                        <img id="photo" class="w-full rounded-lg mb-4" alt="Sua foto aparecerá aqui" style="display: none;" />
                        
                        <div class="flex gap-2 justify-center">
                            <button type="button" id="startCamera" class="btn btn-primary">
                                📷 Abrir Câmera
                            </button>
                            <button type="button" id="takePhoto" class="btn btn-success" style="display: none;">
                                ✅ Capturar
                            </button>
                            <button type="button" id="retakePhoto" class="btn btn-warning" style="display: none;">
                                🔄 Refazer
                            </button>
                        </div>
                        
                        <input type="file" name="image" id="imageInput" accept="image/*" capture="environment" class="file-input file-input-bordered w-full mt-4" />
                        <label class="label">
                            <span class="label-text-alt">Ou use a câmera acima ou selecione uma imagem da galeria</span>
                        </label>
                    </div>
                </div>
                
                <!-- Text Input (OCR Result) -->
                <div class="form-control">
                    <label class="label">
                        <span class="label-text font-semibold">Texto do Trecho *</span>
                    </label>
                    <textarea name="Text" class="textarea textarea-bordered h-32" 
                              placeholder="Digite o texto ou aguarde a extração via OCR..." required></textarea>
                    <label class="label">
                        <span class="label-text-alt">💡 Dica: Em breve, o texto será extraído automaticamente via OCR!</span>
                    </label>
                </div>
                
                <div class="card-actions justify-end">
                    <button type="button" class="btn btn-ghost" @@click="showCaptureForm = false">Cancelar</button>
                    <button type="submit" class="btn btn-primary">
                        💾 Salvar Destaque
                    </button>
                </div>
            </form>
        </div>
        <form method="dialog" class="modal-backdrop">
            <button @@click="showCaptureForm = false">fechar</button>
        </form>
    </dialog>

    <!-- Highlights List -->
    <div class="space-y-4">
        <h2 class="text-xl font-bold mb-4">
            Destaques (@highlights.Count)
        </h2>
        
        @if (!highlights.Any())
        {
            <div class="card bg-base-100 shadow-xl">
                <div class="card-body items-center text-center py-12">
                    <div class="text-5xl mb-4">📝</div>
                    <h3 class="card-title text-lg mb-2">Nenhum destaque ainda</h3>
                    <p class="mb-4">Capture seu primeiro trecho deste livro!</p>
                    <button @@click="showCaptureForm = true" class="btn btn-primary">
                        Capturar Primeiro Destaque
                    </button>
                </div>
            </div>
        }
        else
        {
            @foreach (var highlight in highlights)
            {
                <div class="card bg-base-100 shadow-xl">
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(highlight.ImagePath))
                        {
                            <figure class="mb-4">
                                <img src="@highlight.ImagePath" alt="Trecho capturado" class="rounded-lg max-h-64 object-contain mx-auto" />
                            </figure>
                        }
                        <p class="whitespace-pre-wrap">@highlight.Text</p>
                        <div class="card-actions justify-end items-center mt-4">
                            <span class="text-xs text-base-content/50">
                                @highlight.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            </span>
                            <form asp-controller="Highlights" asp-action="Delete" asp-route-id="@highlight.Id" method="post">
                                <input type="hidden" name="bookId" value="@Model.Id" />
                                <button type="submit" class="btn btn-error btn-sm" onclick="return confirm('Excluir este destaque?')">
                                    Excluir
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        // Camera functionality
        const video = document.getElementById('video');
        const canvas = document.getElementById('canvas');
        const photo = document.getElementById('photo');
        const startCameraBtn = document.getElementById('startCamera');
        const takePhotoBtn = document.getElementById('takePhoto');
        const retakePhotoBtn = document.getElementById('retakePhoto');
        const imageInput = document.getElementById('imageInput');
        
        let stream = null;
        
        startCameraBtn.addEventListener('click', async () => {
            try {
                stream = await navigator.mediaDevices.getUserMedia({ 
                    video: { facingMode: 'environment' } 
                });
                video.srcObject = stream;
                video.style.display = 'block';
                startCameraBtn.style.display = 'none';
                takePhotoBtn.style.display = 'inline-block';
                imageInput.style.display = 'none';
            } catch (err) {
                alert('Erro ao acessar câmera: ' + err.message);
            }
        });
        
        takePhotoBtn.addEventListener('click', () => {
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            canvas.getContext('2d').drawImage(video, 0, 0);
            
            const dataUrl = canvas.toDataURL('image/png');
            photo.src = dataUrl;
            photo.style.display = 'block';
            video.style.display = 'none';
            canvas.style.display = 'none';
            
            takePhotoBtn.style.display = 'none';
            retakePhotoBtn.style.display = 'inline-block';
            
            // Convert to blob and set to hidden input for form submission
            canvas.toBlob((blob) => {
                const file = new File([blob], 'capture.png', { type: 'image/png' });
                const dataTransfer = new DataTransfer();
                dataTransfer.items.add(file);
                imageInput.files = dataTransfer.files;
            }, 'image/png');
        });
        
        retakePhotoBtn.addEventListener('click', () => {
            photo.style.display = 'none';
            video.style.display = 'block';
            takePhotoBtn.style.display = 'inline-block';
            retakePhotoBtn.style.display = 'none';
        });
        
        // Cleanup on modal close
        document.addEventListener('alpine:init', () => {
            Alpine.on('cleanup', () => {
                if (stream) {
                    stream.getTracks().forEach(track => track.stop());
                }
            });
        });
    </script>
}
