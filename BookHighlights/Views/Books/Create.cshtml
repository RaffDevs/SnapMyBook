@model BookHighlights.Application.DTOs.CreateBookDto

@{
    ViewData["Title"] = "Novo Livro";
}

<div class="max-w-md mx-auto">
    <div class="card bg-base-100 shadow-xl">
        <div class="card-body">
            <h1 class="card-title text-2xl mb-4">📖 Cadastrar Novo Livro</h1>
            
            <form asp-controller="Books" asp-action="Create" method="post">
                <div class="form-control mb-4">
                    <label class="label">
                        <span class="label-text font-semibold">Título do Livro *</span>
                    </label>
                    <input asp-for="Title" type="text" placeholder="Ex: Dom Casmurro" 
                           class="input input-bordered w-full" required />
                </div>
                
                <div class="form-control mb-6">
                    <label class="label">
                        <span class="label-text font-semibold">Autor</span>
                    </label>
                    <input asp-for="Author" type="text" placeholder="Ex: Machado de Assis" 
                           class="input input-bordered w-full" />
                </div>
                
                <div class="card-actions justify-end gap-2">
                    <a asp-controller="Books" asp-action="Index" class="btn btn-ghost">Cancelar</a>
                    <button type="submit" class="btn btn-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        Salvar Livro
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
